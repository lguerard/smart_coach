# =============================================================================
#  Configuration Docker — copier en .env puis completer
#    cp .env.example .env
# =============================================================================

# Sujet ntfy.sh secret pour la notification quotidienne (notify.py)
NTFY_TOPIC=change-me-to-a-secret-topic

# Fuseau horaire : pilote l'heure murale du cron (05:30 sync, 06:00 coach)
TZ=Europe/Paris

# Remote rclone (configure via `docker compose run --rm -it
# smart_sport-worker rclone config`) pointant vers le dossier Drive
# ou l'export Health Connect automatique atterrit.
RCLONE_REMOTE=gdrive:HealthConnectExports

# Token OAuth valable 1 an, genere par :
#   docker compose run --rm -it smart_sport-worker claude setup-token
# Auth abonnement Claude (Pro/Max/Team/Enterprise), PAS facturation API.
CLAUDE_CODE_OAUTH_TOKEN=change-me

# Optionnel : bascule vers l'API Anthropic (facturee au token) au lieu
# du CLI Claude ci-dessus. Laisser a claude_cli par defaut.
LLM_PROVIDER=claude_cli
# ANTHROPIC_API_KEY=change-me
