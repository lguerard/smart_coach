# =============================================================================
#  Configuration Docker — copier en .env puis completer
#    cp .env.example .env
# =============================================================================

# Sujet ntfy.sh secret pour la notification quotidienne (notify.py)
NTFY_TOPIC=change-me-to-a-secret-topic

# Fuseau horaire : pilote l'heure murale du cron (05:30 sync, 06:00 coach)
TZ=Europe/Paris

# Remote rclone (configure via `docker compose run --rm -it
# smart_sport-worker rclone config`) pointant vers le dossier Drive
# ou l'export Health Connect automatique atterrit.
RCLONE_REMOTE=gdrive:HealthConnectExports

# Fenetre de recuperation Garmin API (seances + sommeil), en jours.
# Login initial : docker compose run --rm -it smart_sport-worker \
#   python -c "from ingest import garmin_api; garmin_api.get_client('<user>')"
# Monter a 365 une fois pour un backfill initial, puis revenir a 14.
# GARMIN_LOOKBACK_DAYS=14

# Token OAuth valable 1 an, genere par :
#   docker compose run --rm -it smart_sport-worker claude setup-token
# Auth abonnement Claude (Pro/Max/Team/Enterprise), PAS facturation API.
CLAUDE_CODE_OAUTH_TOKEN=change-me

# Optionnel : bascule vers l'API Anthropic (facturee au token) au lieu
# du CLI Claude ci-dessus. Laisser a claude_cli par defaut.
LLM_PROVIDER=claude_cli
# ANTHROPIC_API_KEY=change-me

# Secret des cookies de session (obligatoire des que le dashboard est
# accessible au-dela de votre machine). Generer :
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me

# --- Exposition publique (profil compose "public") -------------------
# Domaine pointant (DNS A/AAAA) vers cette machine ; Caddy obtient le
# certificat HTTPS tout seul. Demarrer avec :
#   docker compose --profile public up -d
# DOMAIN=sport.exemple.fr

# En public : cookie de session marque Secure (jamais envoye en HTTP)
# COOKIE_SECURE=1

# En public : ne plus exposer le port applicatif en clair, Caddy
# devient la seule porte d'entree.
# WEB_BIND=127.0.0.1:8080
